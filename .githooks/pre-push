#!/usr/bin/env bash
#
# Pre-push version guard.
# Refuses to push `main` unless the tip commit sits on a release tag — i.e. the
# version was bumped via `npm run release:dev` (or release:patch / release:minor).
# This makes "forgot to bump the version" structurally impossible.
#
# Enable on a checkout with:  npm run setup:hooks
# Bypass once (emergencies):  git push --no-verify
#
zero="0000000000000000000000000000000000000000"
blocked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Only guard pushes to main.
  [ "$remote_ref" = "refs/heads/main" ] || continue
  # Branch deletion — nothing to check.
  [ "$local_sha" = "$zero" ] && continue

  if ! git describe --tags --exact-match "$local_sha" >/dev/null 2>&1; then
    short=$(git rev-parse --short "$local_sha")
    ver=$(node -p "require('./package.json').version" 2>/dev/null || echo "?")
    echo ""                                                                      >&2
    echo "  ✗ push blocked: commit $short on main is not at a release tag."      >&2
    echo "    package.json is $ver, but this commit has no matching tag —"       >&2
    echo "    you're pushing changes without a version bump."                    >&2
    echo ""                                                                      >&2
    echo "    Ship it:  npm run release:dev    # bump dev build, tag, and push"  >&2
    echo "    Bypass:   git push --no-verify"                                    >&2
    echo ""                                                                      >&2
    blocked=1
  fi
done

exit $blocked
